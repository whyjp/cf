# Auto-added by etago (Q-D9 answer 1 — real env paste).
# Never commit secrets; .env.template is the catalog, .env is the vault.
.env
.env.*
!.env.template

# Build artifacts
etago/etago
etago/etago.exe
etago/dist/

# Test cache + AppControl-workaround compiled tests
etago/.gocache/
etago/.gotmp/
etago/*.test.exe
etago/cmd-etago.test.exe
etago/smoke.test.exe
etago/*.out
etago/coverage.txt

# IDE
.vscode/
.idea/

# OMC harness session-local state (transient)
.omc/

# uv workspace (single venv at root)
.venv/
__pycache__/
*.pyc

# pytest
.pytest_cache/
.coverage

# runtime (pid + log)
.run/
*.pid
*.log

# crawler data dirs (also covered by per-package .gitignore)
crawl/*/data/

# SP-D D-0 ONNX PoC: model + tokenizer binaries (~hundreds of MB), runtime libs
poc/d0-onnx/onnx_model/
poc/d0-onnx/tokenizer/
poc/d0-onnx/onnxruntime.dll
poc/d0-onnx/onnxruntime.lib
poc/d0-onnx/onnxruntime.so
poc/d0-onnx/libonnxruntime*.dylib
poc/d0-onnx/libonnxruntime*.so*
poc/d0-onnx/d0-poc
poc/d0-onnx/d0-poc.exe

# SP-D D-1 falkor-go smoke: transient go module generated by scripts/falkor-go-smoke.sh
smoke/

# SP-D D-8 cutover (2026-05-11): be-api is the Go binary at backend/be-api/.
# Build outputs + runtime DLLs + ONNX assets all live next to the .exe and
# must NOT be committed (DLLs are ~5MB, assets-onnx/ is ~423MB).
backend/be-api/be-api
backend/be-api/be-api.exe
backend/be-api/*.dll
backend/be-api/*.lib
backend/be-api/*.so
backend/be-api/*.dylib
backend/be-api/be-api.log
backend/be-api/be-api.err.log
backend/be-api/.run/
backend/be-api/assets-onnx/
backend/be-api/.gocache/
backend/be-api/.gotmp/
backend/be-api/*.test.exe

# Playwright test artifacts
fe/test-results/
fe/playwright-report/
