# etago — runtime credential template.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Naver Cloud Platform (NCP) Maps APIs — used by --source naver path.
# Get keys at: https://console.ncloud.com → Services → AI·Application Service → Maps
#   - Application 등록 → Service: Geocoding + Directions 5
#   - 인증 정보 → Client ID + Client Secret
# Free tier: ~60k Directions calls / month, ~30k Geocoding / month (subject to NCP pricing).
NCP_CLIENT_ID=your-ncp-client-id-here
NCP_CLIENT_SECRET=your-ncp-client-secret-here
